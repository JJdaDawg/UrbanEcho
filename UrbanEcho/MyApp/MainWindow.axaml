<u:UrsaWindow
    x:Class="MyApp.MainWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:u="https://irihi.tech/ursa"
    xmlns:mapsui="clr-namespace:Mapsui.UI.Avalonia;assembly=Mapsui.UI.Avalonia"
    xmlns:local="clr-namespace:MyApp"
    Height="1080"
    Width="1920"
    Title="Urban Echo"
    WindowState="Maximized"
    ExtendClientAreaToDecorationsHint="True"
    ExtendClientAreaChromeHints="NoChrome"
    ExtendClientAreaTitleBarHeightHint="32"
    TransparencyLevelHint="Mica">

    <!-- Title bar -->
    <u:UrsaWindow.TitleBarContent>
        <local:MenuBar/>
    </u:UrsaWindow.TitleBarContent>

    <!-- Main area -->
    <Grid Margin="0,32,0,0" RowDefinitions="*,Auto" ColumnDefinitions="*,300">
        <!-- Map -->
        <mapsui:MapControl x:Name="MyMapControl" Grid.Row="0" Grid.Column="0"/>

        <!-- Right panel -->
        <Grid Grid.Row="0" Grid.Column="1" RowDefinitions="*,*">

            <!-- Project Explorer -->
            <Border Grid.Row="0" Margin="1">
                <TextBlock Text="Project Explorer" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>

            <!-- Properties -->
            <Border Grid.Row="1" Margin="1">
                <local:PropertiesPanel Grid.Row="1"/>
            </Border>

            <!-- Horizontal splitter -->
            <GridSplitter Grid.Row="0" Height="4" HorizontalAlignment="Stretch" VerticalAlignment="Bottom" ResizeDirection="Rows"/>
        </Grid>

        <!-- Vertical splitter -->
        <GridSplitter Grid.Row="0" Grid.Column="0" Width="4" HorizontalAlignment="Right" VerticalAlignment="Stretch" ResizeDirection="Columns"/>

        <!-- Footer -->
        <local:FooterBar Grid.Row="1" Grid.ColumnSpan="2"/>
    </Grid>

</u:UrsaWindow>
