<UserControl
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:Class="MyApp.PropertiesPanel">

    <Border
        CornerRadius="3"
        BorderThickness="1"
        BorderBrush="DimGray"
        Background="#252526"
        Padding="4"
        Margin="4">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="28"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border CornerRadius="6,6,0,0" Padding="4">
                <TextBlock Text="Properties" FontWeight="Bold"/>
            </Border>

            <!-- Properties content -->
            <StackPanel Grid.Row="1" Margin="4">

            </StackPanel>
        </Grid>

    </Border>
</UserControl>
