<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1920" d:DesignHeight="1080"
             x:Class="MyApp.MenuBar">

    <!-- MENU BAR -->
    <Menu DockPanel.Dock="Left" Background="Transparent" Foreground="White">
        <MenuItem Header="Project">
            <MenuItem Header="Open"/>
            <MenuItem Header="Save"/>
        </MenuItem>
        <MenuItem Header="Simulation">
            <MenuItem Header="Start"/>
            <MenuItem Header="Pause"/>
        </MenuItem>
        <MenuItem Header="View">
            <MenuItem Header="Traffic Volume"/>
            <MenuItem Header="Road Names"/>
        </MenuItem>
        <MenuItem Header="Tools">
            <MenuItem Header="Edit Mode"/>
            <MenuItem Header="Settings"/>
        </MenuItem>
    </Menu>

</UserControl>
