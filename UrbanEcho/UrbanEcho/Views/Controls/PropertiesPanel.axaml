<UserControl
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:UrbanEcho"
    xmlns:vm="using:UrbanEcho.ViewModels"
    xmlns:propVm="using:UrbanEcho.ViewModels.Properties"
    x:Class="UrbanEcho.PropertiesPanel"
    x:DataType="vm:PropertiesPanelViewModel"
    d:DesignHeight="500"
    d:DesignWidth="300">

    <Border Classes="focus-indicator" Focusable="True" Padding="0">
        <Grid RowDefinitions="32, Auto, *">

            <!-- Title bar -->
            <Border Grid.Row="0">
                <Grid ColumnDefinitions="*, Auto">
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0,0,0" Spacing="5">
                        <TextBlock Text="{Binding Title}"/>
                        <TextBlock Text="{Binding Subtitle}"
                                   IsVisible="{Binding HasSelection}"
                                   FontSize="11"
                                   Opacity="0.6"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" IsVisible="{Binding HasSelection}" Spacing="2">
                        <Button Content="Edit"
                                Height="22" Padding="8,0"
                                IsVisible="{Binding IsNotEditing}"
                                Command="{Binding EditCommand}"/>
                        <Button Content="Cancel"
                                Height="22" Padding="8,0"
                                IsVisible="{Binding IsEditing}"
                                Command="{Binding CancelCommand}"/>
                    </StackPanel>
                    <Button Classes="CloseButtonStyle" Margin="2,0,0,0" Command="{Binding ToggleCommand}"/>
                </StackPanel>
                </Grid>
            </Border>

            <Separator Grid.Row="1" Margin="0" />

            <!-- Content area -->
            <ScrollViewer Grid.Row="2" Margin="2">
                <Panel>
                    <TextBlock
                        Text="No project loaded"
                        IsVisible="{Binding !HasProject}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Opacity="0.5"/>
                    <TextBlock
                        Text="Select an object on the map"
                        IsVisible="{Binding ShowEmptyMapMessage}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Opacity="0.5"/>
                    <ContentControl
                        Content="{Binding SelectedProperties}"
                        IsVisible="{Binding HasSelection}">
                        <ContentControl.DataTemplates>
                            <DataTemplate DataType="{x:Type propVm:VehiclePropertiesViewModel}">
                                <local:VehiclePropertiesView/>
                            </DataTemplate>
                            <DataTemplate DataType="{x:Type propVm:RoadPropertiesViewModel}">
                                <local:RoadPropertiesView/>
                            </DataTemplate>
                            <DataTemplate DataType="{x:Type propVm:SignalPropertiesViewModel}">
                                <local:SignalPropertiesView/>
                            </DataTemplate>
                            <DataTemplate DataType="{x:Type propVm:SpawnerPropertiesViewModel}">
                                <local:SpawnerPropertiesView/>
                            </DataTemplate>
                        </ContentControl.DataTemplates>
                    </ContentControl>
                </Panel>
            </ScrollViewer>

        </Grid>
    </Border>
</UserControl>