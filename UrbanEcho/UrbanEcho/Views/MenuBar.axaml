<UserControl 
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:UrbanEcho"
    xmlns:viewmodels="using:UrbanEcho.ViewModels"
    xmlns:icon="clr-namespace:FluentIcons.Avalonia;assembly=FluentIcons.Avalonia"
    x:Class="UrbanEcho.MenuBar"
    x:DataType="vm:MainViewModel"
    xmlns:vm="clr-namespace:UrbanEcho.ViewModels">
    <Border>
        <DockPanel>

            <!-- Menu bar -->
            <Menu DockPanel.Dock="Left"
                    HorizontalAlignment="Left"
                    Height="32">

                <MenuItem Header="Project">
                    <MenuItem Header="_Open Project" Background="Transparent" Command="{Binding Project.OpenProjectCommand}">
                        <MenuItem.Icon>
							<icon:SymbolIcon Symbol="FolderOpen"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="_New Project" Command="{Binding Project.CreateProjectCommand}">
                        <MenuItem.Icon>
							<icon:SymbolIcon Symbol="AddSquare"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <Separator />
                    <MenuItem Header="_Save Project" Command="{Binding Project.SaveProjectCommand}">
                        <MenuItem.Icon>
							<icon:SymbolIcon Symbol="Save" Foreground="LightSkyBlue"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Save Project As..." Command="{Binding Project.SaveAsProjectCommand}"/>
                    <Separator />
                    <MenuItem Header="Close Project" Command="{Binding Project.CloseProjectCommand}">
                        <MenuItem.Icon>
							<icon:SymbolIcon Symbol="DismissSquare"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Import Data" IsEnabled="{Binding Project.HasProject}">
                        <MenuItem Header="Background" Command="{Binding Project.ImportBackgroundCommand}" />
                        <MenuItem Header="Roads" Command="{Binding Project.ImportRoadsCommand}" />
                        <MenuItem Header="Intersections" Command="{Binding Project.ImportIntersectionsCommand}" />
                    </MenuItem>
                </MenuItem>

                <MenuItem Header="Simulation">
                    <MenuItem Header="Start" Command="{Binding Simulation.StartCommand}">
                        <MenuItem.Icon>
							<icon:SymbolIcon Symbol="Play" Foreground="LightGreen" IconVariant="Filled"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Stop" Command="{Binding Simulation.StopCommand}">
                        <MenuItem.Icon>
							<icon:SymbolIcon Symbol="Stop" Foreground="IndianRed" IconVariant="Filled"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Pause" Command="{Binding Simulation.PauseCommand}">
                        <MenuItem.Icon>
							<icon:SymbolIcon Symbol="Pause" IconVariant="Filled"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <Separator />
                    <MenuItem Header="Speed Up" Command="{Binding Simulation.SpeedUpCommand}">
                        <MenuItem.Icon>
							<icon:SymbolIcon Symbol="Next"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Speed Down" Command="{Binding Simulation.SpeedDownCommand}">
                        <MenuItem.Icon>
							<icon:SymbolIcon Symbol="Previous"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <Separator />
                    <MenuItem Header="Use Real Time Data" Command="{Binding Simulation.RealTimeCommand}">
                        <MenuItem.Icon>
							<icon:SymbolIcon Symbol="LocationLive"/>
                        </MenuItem.Icon>
                    </MenuItem>
                </MenuItem>

                <MenuItem Header="View">
                    <MenuItem Header="Traffic Volume"
                              IsChecked="{Binding Map.IsVolumeVisible}"
                              ToggleType="CheckBox"
                              Command="{Binding Map.ToggleVolumeCommand}">                                
                        <MenuItem.Icon>
							<icon:SymbolIcon Symbol="DataBarVertical"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Traffic Speed Heatmap"
                              IsChecked="{Binding Map.IsTrafficSpeedVisible}"
                              ToggleType="CheckBox"
                              Command="{Binding Map.ToggleTrafficSpeedCommand}">                          
                              
                        <MenuItem.Icon>
							<icon:SymbolIcon Symbol="TopSpeed"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <Separator />
                    <MenuItem Header="Layers">
                        <MenuItem.Icon>
							<icon:SymbolIcon Symbol="Layer"/>
                        </MenuItem.Icon>
						<MenuItem Header="Raster Background Image"
                                  IsChecked="{Binding Map.IsRasterVisible}"
                                  ToggleType="CheckBox"
                                  Command="{Binding Map.ToggleRasterCommand}"/>
                        <MenuItem Header="Road Layer"
                                  IsChecked="{Binding Map.IsRoadVisible}"
                                  ToggleType="CheckBox"
                                  Command="{Binding Map.ToggleRoadCommand}"/>
                        <MenuItem Header="Census Overlay"
                                  IsChecked="{Binding Map.IsCensusOverlayVisible}"
                                  ToggleType="CheckBox"
                                  Command="{Binding Map.ToggleCensusOverlayCommand}"/>
                        <MenuItem Header="Intersection Details"
                                  IsChecked="{Binding Map.IsIntersectionsVisible}"
                                  ToggleType="CheckBox"
                                  Command="{Binding Map.ToggleIntersectionDetailsCommand}"/>
                    </MenuItem>
                    <Separator />
                    <MenuItem Header="Console Window"
                              Command="{Binding Console.ToggleCommand}">
                        <MenuItem.Icon>
							<icon:SymbolIcon Symbol="WindowConsole"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Project Explorer"
                              Command="{Binding ProjectExplorer.ToggleCommand}">
                        <MenuItem.Icon>
							<icon:SymbolIcon Symbol="Library"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Statistics Window">
                        <MenuItem.Icon>
							<icon:SymbolIcon Symbol="ChartMultiple"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Properties Window"
                              Command="{Binding Properties.ToggleCommand}">
                        <MenuItem.Icon>
							<icon:SymbolIcon Symbol="TableCellsSplit"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <Separator/>
                    <MenuItem Header="Real Time Data...">
                        <MenuItem.Icon>
							<icon:SymbolIcon Symbol="LocationLive"/>
                        </MenuItem.Icon>
                    </MenuItem>
                </MenuItem>

                <MenuItem Header="Reports">
                    <MenuItem Header="Export Report...">
                        <MenuItem.Icon>
							<icon:SymbolIcon Symbol="ArrowDownload"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="View Export">
                        <MenuItem.Icon>
							<icon:SymbolIcon Symbol="DocumentSearch"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Open Report">
                        <MenuItem.Icon>
							<icon:SymbolIcon Symbol="FolderOpen"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Compare Reports...">
                        <MenuItem.Icon>
							<icon:SymbolIcon Symbol="DocumentOnePageMultiple"/>
                        </MenuItem.Icon>
                    </MenuItem>
                </MenuItem>

                <MenuItem Header="Tools">
                    <MenuItem Header="Edit Mode"
                              Command="{Binding EditMode.ToggleEditModeCommand}">
                        <MenuItem.Icon>
							<icon:SymbolIcon Symbol="DesktopEdit"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <Separator />
                    <MenuItem Header="Create Roads"
                              Command="{Binding EditMode.CreateRoadCommand}">
                        <MenuItem.Icon>
							<icon:SymbolIcon Symbol="Add" Foreground="LightGreen"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Create Traffic Signalling"
                              Command="{Binding EditMode.CreateTrafficSignalCommand}">
                        <MenuItem.Icon>
							<icon:SymbolIcon Symbol="Add" Foreground="LightGreen"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Delete Roads"
                              Command="{Binding EditMode.DeleteRoadCommand}">
                        <MenuItem.Icon>
							<icon:SymbolIcon Symbol="Delete" Foreground="IndianRed"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Delete Traffic Signalling"
                              Command="{Binding EditMode.DeleteTrafficSignalCommand}">
                        <MenuItem.Icon>
							<icon:SymbolIcon Symbol="Delete" Foreground="IndianRed"/>
                        </MenuItem.Icon>
                    </MenuItem>
                </MenuItem>
            </Menu>

        </DockPanel>
    </Border>
</UserControl>
