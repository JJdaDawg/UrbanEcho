<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:UrbanEcho.ViewModels.Properties"
             mc:Ignorable="d" d:DesignWidth="300" d:DesignHeight="500"
             x:Class="UrbanEcho.SignalPropertiesView"
             x:DataType="vm:SignalPropertiesViewModel">

    <StackPanel Spacing="0">

        <StackPanel Margin="10,10" Spacing="8">
            <TextBlock Text="INFO" Opacity="0.5" />
            <StackPanel Spacing="2">
                <TextBlock Text="Name" Opacity="0.5" />
                <TextBlock Text="{Binding Name}" TextWrapping="Wrap" Opacity="0.85" />
            </StackPanel>
            <StackPanel Spacing="2">
                <TextBlock Text="Type" Opacity="0.5" />
                <TextBlock Text="{Binding Type}" TextWrapping="Wrap" Opacity="0.85" />
            </StackPanel>
            <StackPanel Spacing="2">
                <TextBlock Text="Status" Opacity="0.5" />
                <TextBlock Text="{Binding Status}" Opacity="0.85" />
            </StackPanel>
            <StackPanel Spacing="2">
                <TextBlock Text="Municipality" Opacity="0.5" />
                <TextBlock Text="{Binding Municipality}" Opacity="0.85" />
            </StackPanel>
            <StackPanel Spacing="2">
                <TextBlock Text="Owned By" Opacity="0.5" />
                <TextBlock Text="{Binding OwnedBy}" Opacity="0.85" />
            </StackPanel>
            <StackPanel Spacing="2">
                <TextBlock Text="Maintained By" Opacity="0.5" />
                <TextBlock Text="{Binding MaintainedBy}" Opacity="0.85" />
            </StackPanel>
        </StackPanel>

        <Separator />

        <StackPanel Margin="14,10" Spacing="4">
            <TextBlock Text="ROADS" Opacity="0.5" />
            <ItemsControl ItemsSource="{Binding ConnectingRoads}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" Opacity="0.85" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>

    </StackPanel>

</UserControl>