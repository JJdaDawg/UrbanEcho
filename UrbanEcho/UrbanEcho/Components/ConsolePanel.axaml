<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:UrbanEcho.ViewModels"
             xmlns:icon="clr-namespace:FluentIcons.Avalonia;assembly=FluentIcons.Avalonia"
             mc:Ignorable="d"
             d:DesignHeight="200"
             d:DesignWidth="1620"
             x:Class="UrbanEcho.ConsolePanel"
             x:DataType="vm:ConsoleViewModel"
             IsVisible="{Binding IsVisible}">

    <Border Classes="focus-indicator" Focusable="True" Padding="0">
        <Grid RowDefinitions="32, Auto, *">

            <!-- Header -->
            <Border Grid.Row="0">
                <Grid ColumnDefinitions="*, Auto">
                    <TextBlock Text="Console" 
                               Grid.Column="0"
                               VerticalAlignment="Center" 
                               Margin="10,0,0,0"/>
                    <Button Grid.Column="1"
                        Classes="CloseButtonStyle"
                        Command="{Binding ToggleCommand}" />
                </Grid>
            </Border>

            <!-- Toolbar -->
            <Border Grid.Row="1" 
                    BorderThickness="1"
                    Padding="10,0,0,5">
                <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                    <TextBlock Text="Output Source:" 
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
                    <ComboBox Width="150" 
                              Height="22"
                              MinHeight="22"
                              Padding="5,0"
                              VerticalAlignment="Center"
                              VerticalContentAlignment="Center"
                              SelectedIndex="{Binding SelectedSource}">
                        <ComboBoxItem Content="System"/>
                        <ComboBoxItem Content="Map Engine"/>
                    </ComboBox>
                    <Rectangle Width="1" Height="16" Fill="DimGray" Margin="5,0,0,0"/>
                    <Button Classes="ClearConsoleButton"
                            Command="{Binding ClearConsoleCommand}"
                            VerticalAlignment="Center"
                            Background="Transparent"
                            BorderThickness="0"
                            Padding="1">
                        <icon:SymbolIcon Symbol="TextCollapse" FontSize="14"/>
                    </Button>
                </StackPanel>
            </Border>

            <!-- Log List -->
            <Grid Grid.Row="2">
                <TextBox Text="{Binding LogText}"
                         IsReadOnly="True"
                         Background="Transparent"
                         BorderThickness="0"
                         Padding="10,5"
                         TextWrapping="Wrap"
                         FontSize="12"
                         FontFamily="Cascadia Code,Consolas,Monospace"
                         Name="ConsoleTextBox"
                         AcceptsReturn="True"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"/>
            </Grid>
        </Grid>
    </Border>
</UserControl>
