<UserControl
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    x:Class="UrbanEcho.PropertiesPanel"
    xmlns:vm="using:UrbanEcho.ViewModels"
    x:DataType="vm:PropertiesViewModel"
    d:DesignHeight="500"
    d:DesignWidth="300">

    <Border Classes="focus-indicator" Focusable="True" Padding="0">
        <Grid RowDefinitions="32,*">

            <!-- Title bar -->
            <Border Grid.Row="0">
                <Grid ColumnDefinitions="*, Auto">
                    <TextBlock Text="Properties" 
                               Grid.Column="0"
                               VerticalAlignment="Center" 
                               Margin="10,0,0,0"/>
                    <Button Grid.Column="1"
                        Classes="CloseButtonStyle"
                        Command="{Binding CloseCommand}" />
                </Grid>
            </Border>

            <!-- Properties content -->
            <StackPanel Grid.Row="1" Margin="4">

            </StackPanel>
        </Grid>
    </Border>

</UserControl>
