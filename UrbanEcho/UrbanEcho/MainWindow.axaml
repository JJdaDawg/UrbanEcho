<Window x:Class="UrbanEcho.MainWindow"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:UrbanEcho"
        xmlns:mapsui="clr-namespace:Mapsui.UI.Avalonia;assembly=Mapsui.UI.Avalonia"
        xmlns:vm="using:UrbanEcho.ViewModels"
        Width="1920" Height="1080"
        Title="Urban Echo"
        WindowState="Maximized"
        TransparencyLevelHint="Mica"
        Background="Transparent"
        x:DataType="vm:MainViewModel">

    <Grid RowDefinitions="Auto,Auto,*,Auto">

        <!-- MenuBar -->
        <local:MenuBar Grid.Row="0" Height="32" DataContext="{Binding}"/>

        <!-- QuickToolbar -->
        <local:QuickToolbar Grid.Row="1"
                            Margin="5,0,5,0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            DataContext="{Binding}"
                            Focusable="False"/>

        <!-- Main Content Area -->
        <Grid Grid.Row="2" x:Name="MainContentGrid"
              ColumnDefinitions="*,4,300"
              Margin="5,5,5,5">

            <!-- LEFT: Map (top) and Console (bottom) -->
            <Grid Grid.Column="0" x:Name="LeftGrid"
                  RowDefinitions="*,5,180">

                <!-- Map -->
                <Border Grid.Row="0" Classes="focus-indicator" Focusable="True">
                    <local:MapView />
                </Border>

                <!-- Splitter between Map and Console -->
                <GridSplitter Grid.Row="1"
                              x:Name="ConsoleSplitter"
                              ResizeDirection="Rows"
                              HorizontalAlignment="Stretch"
                              Height="4"
                              Background="Transparent"/>

                <!-- Console -->
                <Border Grid.Row="2" x:Name="ConsoleBorder">
                    <local:ConsolePanel DataContext="{Binding Console}"/>
                </Border>
            </Grid>

            <!-- Splitter between Left and Right columns -->
            <GridSplitter Grid.Column="1"
                          x:Name="RightPanelSplitter"
                          ResizeDirection="Columns"
                          VerticalAlignment="Stretch"
                          Width="4"
                          Background="Transparent"/>

            <!-- RIGHT: Project Explorer (top) and Properties (bottom) -->
            <Grid Grid.Column="2" x:Name="RightGrid"
                  RowDefinitions="*,4,*">

                <!-- Project Explorer -->
                <local:ProjectExplorerPanel Grid.Row="0" DataContext="{Binding ProjectExplorer}"/>

                <!-- Splitter between Project Explorer and Properties -->
                <GridSplitter Grid.Row="1"
                              x:Name="PropertiesSplitter"
                              ResizeDirection="Rows"
                              HorizontalAlignment="Stretch"
                              Height="4"
                              Background="Transparent"/>

                <!-- Properties -->
                <local:PropertiesPanel Grid.Row="2" DataContext="{Binding Properties}"/>
            </Grid>
        </Grid>

        <!-- Footer -->
        <local:FooterBar Grid.Row="3" DataContext="{Binding}"/>

    </Grid>
</Window>