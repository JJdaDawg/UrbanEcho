<Window xmlns="https://github.com/avaloniaui"
        xmlns:compilerservices="using:System.Runtime.CompilerServices"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="using:UrbanEcho"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewmodel="using:UrbanEcho.ViewModel"
        xmlns:vm="using:UrbanEcho.ViewModels"
        xmlns:mapsui="clr-namespace:Mapsui.UI.Avalonia;assembly=Mapsui.UI.Avalonia"
        
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="UrbanEcho.MainWindow"
        Title="MyApp">

        <Grid >
            <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="200" />
                </Grid.RowDefinitions>
        <mapsui:MapControl x:Name="MyMapControl" Grid.Row="0"/> 

            <TextBox
                 TextWrapping="NoWrap"
                 AcceptsReturn="True"
                 ScrollViewer.VerticalScrollBarVisibility="Visible"
                 ScrollViewer.HorizontalScrollBarVisibility="Visible"        
                 Text="{Binding ConsoleText}" Name="ConsoleLog" Grid.Row="1" x:DataType="vm:MainViewModel"                   
             /> 

        </Grid>
</Window>
