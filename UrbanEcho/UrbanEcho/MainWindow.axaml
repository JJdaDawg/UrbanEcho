<Window x:Class="UrbanEcho.MainWindow"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:UrbanEcho"
        xmlns:mapsui="clr-namespace:Mapsui.UI.Avalonia;assembly=Mapsui.UI.Avalonia"
        xmlns:vm="using:UrbanEcho.ViewModels"
        Width="1920"
        Height="1080"
        Title="Urban Echo"
        WindowState="Maximized"
        TransparencyLevelHint="Mica"
        Background="Transparent"
        x:DataType="vm:MainViewModel">

    <Grid RowDefinitions="Auto,Auto,*">
        
        <!-- MenuBar -->
        <local:MenuBar Grid.Row="0" DataContext="{Binding}" Height="32"/>

        <!-- QuickToolbar -->
        <local:QuickToolbar Grid.Row="1"
                            DataContext="{Binding}" 
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            Margin="5,0,5,5"
                            Focusable="False"/>

        <!-- Main Content -->
        <Grid Grid.Row="2" RowDefinitions="*,Auto" ColumnDefinitions="*,300">

            <!-- Left Column: Map and Console -->
            <Grid Grid.Row="0" Grid.Column="0" RowDefinitions="*,Auto,200">

                <!-- Map -->
                <Border Classes="focus-indicator"
                        Focusable="True"
                        Margin="5 0 0 0">
                    <mapsui:MapControl Map="{Binding Map.MyMap}" x:Name="MyMapControl"/>
                </Border>

                <!-- Horizontal splitter between map and console -->
                <GridSplitter Grid.Row="1" Background="Transparent" ResizeDirection="Rows" Height="5"/>

                <!-- Console Panel -->
                <Border Grid.Row="2" Margin="5 0 0 5" Classes="focus-indicator" Focusable="True">
                    <local:ConsolePanel DataContext="{Binding Console}"/>
                </Border>

            </Grid>

            <!-- Right Column: Project Explorer and Properties -->
            <Grid Grid.Row="0" Grid.Column="1" RowDefinitions="*,Auto,*">

                <!-- Project Explorer -->
                <Border Grid.Row="0" Margin="5 0 5 0" Classes="focus-indicator" Focusable="True">
                    <local:ProjectExplorerPanel/>
                </Border>

                <!-- Horizontal splitter -->
                <GridSplitter Grid.Row="1" Height="6" Background="Transparent" ResizeDirection="Rows"/>

                <!-- Properties Panel -->
                <Border Grid.Row="2" Margin="5 0 5 5" Classes="focus-indicator" Focusable="True">
                    <local:PropertiesPanel/>
                </Border>

            </Grid>

            <!-- Vertical splitter between left and right columns -->
            <GridSplitter Grid.Row="0" Grid.Column="0" Width="6" Background="Transparent" 
                          HorizontalAlignment="Right" ResizeDirection="Columns"/>

            <!-- Footer -->
            <local:FooterBar Grid.Row="1" Grid.ColumnSpan="2" DataContext="{Binding}"/>
        </Grid>
    </Grid>
</Window>
