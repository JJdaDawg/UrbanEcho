<Window x:Class="UrbanEcho.MainWindow"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:UrbanEcho"
        xmlns:mapsui="clr-namespace:Mapsui.UI.Avalonia;assembly=Mapsui.UI.Avalonia"
        xmlns:vm="using:UrbanEcho.ViewModels"
        Width="1920"
        Height="1080"
        Title="Urban Echo"
        WindowState="Maximized"
        TransparencyLevelHint="Mica"
        Background="Transparent"
        x:DataType="vm:MainViewModel">

    <Grid RowDefinitions="Auto,*">
        
        <Grid Grid.Row="0" Height="32" Background="Transparent">
            <local:MenuBar DataContext="{Binding}" VerticalAlignment="Center"/>
        </Grid>

        <Grid Grid.Row="1" RowDefinitions="*,Auto" ColumnDefinitions="*,300">

            <Grid Grid.Row="0" Grid.Column="0" RowDefinitions="*,Auto,200">
                <mapsui:MapControl x:Name="MyMapControl" Grid.Row="0"/>
                <local:QuickToolbar DataContext="{Binding}" HorizontalAlignment="Left" VerticalAlignment="Top"/>
                
                <GridSplitter Grid.Row="1" Background="Transparent" ResizeDirection="Rows" Height="5"/>

                <Border Grid.Row="2" Margin="5 0 0 5">
                    <local:ConsolePanel DataContext="{Binding Console}"/>
                </Border>
            </Grid>

            <Grid Grid.Row="0" Grid.Column="1" RowDefinitions="*,Auto,*">
                <Border Grid.Row="0" Margin="5 0 5 0">
                    <local:ProjectExplorerPanel/>
                </Border>

                <GridSplitter Grid.Row="1" Height="6" Background="Transparent" ResizeDirection="Rows"/>

                <Border Grid.Row="2" Margin="5 0 5 5">
                    <local:PropertiesPanel/>
                </Border>
            </Grid>

            <GridSplitter Grid.Row="0" Grid.Column="0" Width="6" Background="Transparent" 
                          HorizontalAlignment="Right" ResizeDirection="Columns"/>

            <local:FooterBar Grid.Row="1" Grid.ColumnSpan="2" DataContext="{Binding}"/>
        </Grid>
    </Grid>
</Window>