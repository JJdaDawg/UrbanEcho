<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sty="using:FluentAvalonia.Styling"
             x:Class="UrbanEcho.App"
             xmlns:icon="clr-namespace:FluentIcons.Avalonia;assembly=FluentIcons.Avalonia"
             RequestedThemeVariant="Default">

    <Application.Styles>

        <sty:FluentAvaloniaTheme />

        <!-- Global Font Size -->
        <Style Selector=":is(TemplatedControl)">
            <Setter Property="FontSize" Value="11" />
        </Style>

        <!-- Global size for all icons -->
        <Style Selector="icon|SymbolIcon">
            <Setter Property="Width" Value="24"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="FontSize" Value="20"/>
        </Style>

        <Style Selector=":is(Window)[ActualTransparencyLevel=Mica][IsActive=True]">
            <Setter Property="Background" Value="Transparent" />
        </Style>

    </Application.Styles>

</Application>
