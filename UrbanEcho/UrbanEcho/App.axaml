<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sty="using:FluentAvalonia.Styling"
             x:Class="UrbanEcho.App"
             xmlns:icon="clr-namespace:FluentIcons.Avalonia;assembly=FluentIcons.Avalonia"
             RequestedThemeVariant="Default">

    <Application.Styles>

        <sty:FluentAvaloniaTheme />

        <!-- Global Font Size -->
        <Style Selector=":is(TemplatedControl)">
            <Setter Property="FontSize" Value="11" />
        </Style>

        <!-- Global size for all icons -->
        <Style Selector="icon|SymbolIcon">
            <Setter Property="Width" Value="24"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="FontSize" Value="20"/>
        </Style>

        <Style Selector=":is(Window)[ActualTransparencyLevel=Mica][IsActive=True]">
            <Setter Property="Background" Value="Transparent" />
        </Style>

        <Style Selector="Button.CloseButtonStyle">
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="CornerRadius" Value="0"/>
            <Setter Property="Content">
                <Template>
                    <icon:SymbolIcon Symbol="Dismiss" FontSize="12"/>
                </Template>
            </Setter>
        </Style>


    </Application.Styles>

</Application>
