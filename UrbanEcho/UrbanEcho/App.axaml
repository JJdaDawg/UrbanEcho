<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="UrbanEcho.App"
             xmlns:semi="https://irihi.tech/semi"
             xmlns:u-semi="https://irihi.tech/ursa/themes/semi"
             xmlns:icon="clr-namespace:FluentIcons.Avalonia;assembly=FluentIcons.Avalonia"
             RequestedThemeVariant="Default">

    <Application.Styles>

        <semi:SemiTheme/>
        <u-semi:SemiTheme/>

        <!-- Global Font Size -->
        <Style Selector=":is(TemplatedControl)">
            <Setter Property="FontSize" Value="11" />
        </Style>

        <!-- Global size for all icons -->
        <Style Selector="icon|SymbolIcon">
            <Setter Property="Width" Value="24"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="FontSize" Value="15"/>
        </Style>

        <Style Selector=":is(Window)[ActualTransparencyLevel=Mica][IsActive=True]">
            <Setter Property="Background" Value="Transparent" />
        </Style>

    </Application.Styles>

</Application>
